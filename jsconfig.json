{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "target": "ES2022",
    "module": "esnext",
    "strict": false,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": [
      "node",
      "mocha"
    ],
    "paths": {
      "electron": ["./types/loose-any.d.ts"],
      "@playwright/test": ["./types/loose-any.d.ts"]
    }
  },
  "exclude": [
    "node_modules",
    ".meteor",
    ".meteor/local",
    ".meteor/local-*",
    ".meteor/packages",
    ".meteor/plugin-cache",
    ".meteor/cordova-build",
    ".meteor/dev_bundle",
    "_build",
    "build",
    "dist",
    "coverage",
    "logs",
    ".desktop-build",
    ".desktop-installer",
    "playwright-report",
    "test-results",
    "tests/fixtures"
  ]
}
